<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- GOOD: Runner.entitlements — Universal Links instead of custom URL schemes.
     From the article section "URL Scheme Hijacking". -->
<plist version="1.0">
<dict>
	<!-- Universal Links: tied to your domain and verified by Apple -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:yourapp.com</string>
		<string>applinks:www.yourapp.com</string>
	</array>
</dict>
</plist>
